{
  "name": "mercatox",
  "version": "1.0.0",
  "description": "Production-ready Node.js + Express backend for MercatoX",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "dev:clean": "npx kill-port ${PORT:-5000} && nodemon server/server.js",
    "worker": "node server/worker.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "mongo:check-indexes": "node server/checkIndexes.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.576.0",
    "mongoose": "^8.11.0",
    "recharts": "^3.7.0",
    "redis": "^5.11.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
